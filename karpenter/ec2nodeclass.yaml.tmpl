apiVersion: karpenter.k8s.aws/v1
kind: EC2NodeClass
metadata:
  name: gpu-nodeclass
spec:
  amiFamily: AL2023
  amiSelectorTerms:                   
    - alias: al2023@latest
  role: ${karpenter_node_role}          
    - tags:
        karpenter.sh/discovery: ${cluster_name}
  securityGroupSelectorTerms:
    - tags:
        karpenter.sh/discovery: ${cluster_name}
  blockDeviceMappings:
    - deviceName: /dev/xvda
      ebs:
        volumeSize: "100Gi"
        volumeType: gp3
        encrypted: true
  tags:
    karpenter.sh/discovery: ${cluster_name}
    Name: karpenter-gpu-node